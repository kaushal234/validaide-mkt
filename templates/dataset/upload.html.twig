{% extends 'base.html.twig' %}

{% block title %}Upload dataset{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h4 mb-0">Upload dataset</h1>
                <a class="btn btn-link" href="{{ path('dataset_index') }}">Back</a>
            </div>

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.name, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.name, {attr: {class: 'form-control'}}) }}
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.file, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.file, {attr: {class: 'form-control'}}) }}

                            {% set fileErrors = form.file.vars.errors %}
                            {% if fileErrors|length > 0 %}
                                <div class="mt-2">
                                    <div class="text-danger small mb-1">
                                        Found {{ fileErrors|length }} problem{{ fileErrors|length > 1 ? 's' : '' }} in the file. Fix them and upload again.
                                    </div>
                                    <div class="border border-danger-subtle rounded p-2 {{ fileErrors|length > 5 ? 'overflow-auto' : '' }}"
                                         {% if fileErrors|length > 5 %}style="max-height: 180px;"{% endif %}>
                                        <ul class="text-danger small mb-0 ps-3">
                                            {% for error in fileErrors %}
                                                <li>{{ error.message }}</li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                </div>
                            {% endif %}
                        </div>

                        <button class="btn btn-primary">Calculate MKT</button>
                    {{ form_end(form) }}
                </div>
            </div>

            <div class="mt-3 small text-muted">
                <p class="mb-1">Expected CSV format: two columns, <code>time</code> and <code>temperature</code> (°C).</p>
                <ul class="mb-0 ps-3">
                    <li>Time may be a Unix timestamp (seconds) or an ISO date-time, e.g. <code>2026-07-01 08:00:00</code>.</li>
                    <li>Temperature is a decimal in Celsius using a dot, e.g. <code>22.5</code>.</li>
                    <li>A header row is optional.</li>
                </ul>
            </div>
        </div>
    </div>
{% endblock %}
