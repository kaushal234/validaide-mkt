{% extends 'base.html.twig' %}

{% block title %}{{ dataset.name }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">{{ dataset.name }}</h1>
        <a class="btn btn-link" href="{{ path('dataset_index') }}">Back</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Submitted</div>
                    <div class="fs-5">{{ dataset.submittedAt|date('Y-m-d H:i') }}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Mean kinetic temperature</div>
                    <div class="fs-5">{{ dataset.mkt is null ? '—' : dataset.mkt|number_format(2) ~ ' °C' }}</div>
                </div>
            </div>
        </div>
    </div>

    {% if dataset.readings|length > 0 %}
        <div class="card mb-4">
            <div class="card-header">Temperature over time</div>
            <div class="card-body">
                <canvas id="temperatureChart" height="120"></canvas>
            </div>
        </div>

        <script type="application/json" id="chartData">
            {{ {
                labels: dataset.readings|map(r => r.recordedAt|date('Y-m-d H:i')),
                temperatures: dataset.readings|map(r => r.temperature),
                mkt: dataset.mkt
            }|json_encode|raw }}
        </script>
    {% endif %}

    <div class="card">
        <div class="card-header">Readings ({{ dataset.readings|length }})</div>
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Recorded at</th>
                        <th class="text-end">Temperature (°C)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reading in dataset.readings %}
                        <tr>
                            <td>{{ reading.recordedAt|date('Y-m-d H:i:s') }}</td>
                            <td class="text-end">{{ reading.temperature|number_format(2) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {% if dataset.readings|length > 0 %}
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                const data = JSON.parse(document.getElementById('chartData').textContent);
                const ctx = document.getElementById('temperatureChart');

                const datasets = [{
                    label: 'Temperature (°C)',
                    data: data.temperatures,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    fill: true,
                    tension: 0.2,
                    pointRadius: 2,
                }];

                if (data.mkt !== null) {
                    datasets.push({
                        label: 'MKT (' + Number(data.mkt).toFixed(2) + ' °C)',
                        data: data.labels.map(() => data.mkt),
                        borderColor: '#dc3545',
                        borderDash: [6, 6],
                        pointRadius: 0,
                        fill: false,
                    });
                }

                new Chart(ctx, {
                    type: 'line',
                    data: { labels: data.labels, datasets: datasets },
                    options: {
                        responsive: true,
                        interaction: { mode: 'index', intersect: false },
                        scales: {
                            y: { title: { display: true, text: '°C' } },
                            x: { ticks: { maxRotation: 45, minRotation: 0 } },
                        },
                    },
                });
            })();
        </script>
    {% endif %}
{% endblock %}
