{% extends 'base.html.twig' %}

{% block title %}{{ dataset.name }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">{{ dataset.name }}</h1>
        <a class="btn btn-link" href="{{ path('dataset_index') }}">Back</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Submitted</div>
                    <div class="fs-5">{{ dataset.submittedAt|date('Y-m-d H:i') }}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Mean kinetic temperature</div>
                    <div class="fs-5">{{ dataset.mkt is null ? '—' : dataset.mkt|number_format(2) ~ ' °C' }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Readings ({{ dataset.readings|length }})</div>
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Recorded at</th>
                        <th class="text-end">Temperature (°C)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reading in dataset.readings %}
                        <tr>
                            <td>{{ reading.recordedAt|date('Y-m-d H:i:s') }}</td>
                            <td class="text-end">{{ reading.temperature|number_format(2) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
